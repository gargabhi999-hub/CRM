# Environment Variables for CRM Deployment
# Copy this file to .env for local development

# Server Configuration
NODE_ENV=production
PORT=3000

# JWT Secret (Generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (Update with your Vercel URL after deployment)
FRONTEND_URL=https://your-crm-portal.vercel.app

# Database (NeDB will store files in data/ directory)
# No additional configuration needed for NeDB

# File Upload Settings
MAX_FILE_SIZE=10mb
UPLOAD_DIR=data/uploads
